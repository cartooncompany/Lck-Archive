DATABASE_URL="postgresql://postgres:postgres@localhost:15432/lck_archive"
PORT="3000"

# LCK sync feature flags
LCK_SYNC_ENABLED="true"
NEWS_SYNC_ENABLED="true"
LCK_DATA_SOURCE="auto"

# Preferred key name for GRID-issued credentials.
# When set, auto mode prefers the GRID GraphQL integration.
GRID_API_KEY="YOUR_GRID_API_KEY"

# Backward-compatible alias used by older code paths.
LOLESPORTS_API_KEY=""

# GRID GraphQL endpoints.
GRID_API_URL="https://api.grid.gg"
GRID_CENTRAL_DATA_URL=""
GRID_SERIES_STATE_URL=""
GRID_TITLE_ID="3"
GRID_TOURNAMENT_NAME_KEYWORD="LCK"
GRID_SERIES_LOOKBACK_DAYS="120"
GRID_SERIES_LOOKAHEAD_DAYS="120"
GRID_QUERY_PAGE_SIZE="50"
GRID_SERIES_STATE_CONCURRENCY="8"
GRID_TEAM_QUERY_CONCURRENCY="4"

# LoL Esports persisted endpoint fallback.
LOLESPORTS_API_URL="https://esports-api.lolesports.com/persisted/gw"
LCK_API_BASE_URL=""
LOLESPORTS_API_LOCALE="ko-KR"
LCK_LEAGUE_ID="98767991310872058"
LCK_TOURNAMENT_ID="113503260417890076"
LCK_SCHEDULE_PAGE_LIMIT="12"
