generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlayerPosition {
  TOP
  JUNGLE
  MID
  ADC
  SUPPORT
  COACH
  SUBSTITUTE
  FLEX
}

enum MatchStatus {
  SCHEDULED
  COMPLETED
  CANCELED
}

enum NewsSource {
  LOLESPORTS
  NAVER_ESPORTS
}

model Team {
  id              String   @id @default(cuid())
  name            String
  shortName       String   @unique
  slug            String   @unique
  logoUrl         String?
  rank            Int?
  wins            Int      @default(0)
  losses          Int      @default(0)
  setWins         Int      @default(0)
  setLosses       Int      @default(0)
  setDifferential Int      @default(0)
  externalSource  String   @default("LCK")
  externalId      String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  players        Player[]
  homeMatches    Match[]                    @relation("HomeTeam")
  awayMatches    Match[]                    @relation("AwayTeam")
  wonMatches     Match[]                    @relation("WinnerTeam")
  wonGames       MatchGame[]                @relation("MatchGameWinnerTeam")
  participations MatchPlayerParticipation[]
  gameStats      MatchGamePlayerStat[]
  supporters     User[]                     @relation("FavoriteTeam")

  @@unique([externalSource, externalId])
  @@index([rank])
}

model User {
  id               String   @id @default(cuid())
  nickname         String
  email            String   @unique
  passwordHash     String
  favoriteTeamId   String
  refreshTokenHash String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  favoriteTeam Team @relation("FavoriteTeam", fields: [favoriteTeamId], references: [id])

  @@index([favoriteTeamId])
}

model Player {
  id               String         @id @default(cuid())
  teamId           String?
  name             String
  slug             String         @unique
  position         PlayerPosition
  profileImageUrl  String?
  realName         String?
  nationality      String?
  birthDate        DateTime?
  recentMatchCount Int            @default(0)
  externalSource   String         @default("LCK")
  externalId       String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  team           Team?                      @relation(fields: [teamId], references: [id], onDelete: SetNull)
  participations MatchPlayerParticipation[]
  gameStats      MatchGamePlayerStat[]

  @@unique([externalSource, externalId])
  @@index([teamId])
  @@index([position])
}

model Match {
  id             String      @id @default(cuid())
  externalSource String      @default("LCK")
  externalId     String
  scheduledAt    DateTime
  seasonYear     Int
  split          String
  stage          String
  matchNumber    String?
  homeTeamId     String
  awayTeamId     String
  homeScore      Int         @default(0)
  awayScore      Int         @default(0)
  winnerTeamId   String?
  status         MatchStatus @default(SCHEDULED)
  vodUrl         String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  homeTeam       Team                       @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam       Team                       @relation("AwayTeam", fields: [awayTeamId], references: [id])
  winnerTeam     Team?                      @relation("WinnerTeam", fields: [winnerTeamId], references: [id])
  participations MatchPlayerParticipation[]
  games          MatchGame[]

  @@unique([externalSource, externalId])
  @@index([scheduledAt])
  @@index([seasonYear, split, stage])
  @@index([homeTeamId, scheduledAt])
  @@index([awayTeamId, scheduledAt])
}

model MatchPlayerParticipation {
  id        String          @id @default(cuid())
  matchId   String
  playerId  String
  teamId    String
  role      PlayerPosition?
  isStarter Boolean         @default(true)
  createdAt DateTime        @default(now())

  match  Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([matchId, playerId])
  @@index([playerId, matchId])
  @@index([teamId, matchId])
}

model MatchGame {
  id             String    @id @default(cuid())
  matchId        String
  externalId     String?
  sequenceNumber Int
  startedAt      DateTime?
  duration       String?
  mapId          String?
  mapName        String?
  winnerTeamId   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  match        Match                 @relation(fields: [matchId], references: [id], onDelete: Cascade)
  winnerTeam   Team?                 @relation("MatchGameWinnerTeam", fields: [winnerTeamId], references: [id], onDelete: SetNull)
  playerStats  MatchGamePlayerStat[]
  draftActions MatchDraftAction[]

  @@unique([matchId, sequenceNumber])
  @@index([matchId])
  @@index([winnerTeamId])
}

model MatchGamePlayerStat {
  id                  String          @id @default(cuid())
  matchGameId         String
  playerId            String
  teamId              String
  role                PlayerPosition?
  participationStatus String?
  characterId         String?
  characterName       String?
  kills               Int?
  deaths              Int?
  assists             Int?
  totalMoneyEarned    Int?
  damageDealt         Int?
  damageTaken         Int?
  visionScore         Float?
  kdaRatio            Float?
  killParticipation   Float?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  matchGame MatchGame @relation(fields: [matchGameId], references: [id], onDelete: Cascade)
  player    Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)
  team      Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([matchGameId, playerId])
  @@index([playerId, matchGameId])
  @@index([teamId, matchGameId])
}

model MatchDraftAction {
  id             String   @id @default(cuid())
  matchGameId    String
  externalId     String?
  type           String
  sequenceNumber String
  sequenceOrder  Int?
  drafterId      String?
  drafterType    String?
  draftableId    String?
  draftableType  String?
  draftableName  String?
  createdAt      DateTime @default(now())

  matchGame MatchGame @relation(fields: [matchGameId], references: [id], onDelete: Cascade)

  @@index([matchGameId])
  @@index([matchGameId, sequenceNumber])
}

model NewsArticle {
  id              String     @id @default(cuid())
  title           String
  summary         String?
  thumbnailUrl    String?
  articleUrl      String
  publisher       String?
  externalSource  NewsSource
  externalId      String
  publishedAt     DateTime?
  publishedAtText String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@unique([externalSource, externalId])
  @@index([publishedAt])
  @@index([externalSource, publishedAt])
}

model SyncJobLog {
  id           String    @id @default(cuid())
  jobName      String
  status       String
  message      String?
  startedAt    DateTime  @default(now())
  finishedAt   DateTime?
  recordsCount Int       @default(0)
  createdAt    DateTime  @default(now())

  @@index([jobName, startedAt])
}
